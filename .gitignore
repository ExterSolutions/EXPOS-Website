# ── Generated at build time from admin API — never commit these ──────────────
# These files are generated by scripts/generate-sitemap.js (prebuild hook).
# Committing them causes cross-client branding contamination (wrong favicon, wrong URLs).
public/favicon.ico
public/sitemap.xml
public/robots.txt
public/browserconfig.xml
public/manifest.json
